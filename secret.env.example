# Apple Developer signing config
# Copy this file to .secret.env and fill in actual values

# Apple ID (for notarization)
APPLE_ID=your-apple-id@example.com

# App-Specific Password (generate at appleid.apple.com)
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Team ID (10 characters)
APPLE_TEAM_ID=XXXXXXXXXX

# Signing identity used by codesign.
# Prefer the full identity string or SHA-1 fingerprint shown by `security find-identity -v -p codesigning`.
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAM_ID)"

# Backward-compatible alias used by older local setups.
APPLE_TEAM_NAME="Developer ID Application: Your Name (TEAM_ID)"
